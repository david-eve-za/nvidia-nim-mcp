{
  "mcp_servers": {
    "nvidia-nim": {
      "name": "nvidia-nim-mcp",
      "description": "NVIDIA NIM MCP Server providing 50+ models for LLM, multimodal, image generation, embeddings, and reranking",
      "command": "node",
      "args": ["dist/index.js"],
      "env": {
        "NVIDIA_API_KEY": "YOUR_NVIDIA_API_KEY_HERE",
        "NVIDIA_NIM_BASE_URL": "https://integrate.api.nvidia.com/v1",
        "LOG_LEVEL": "info",
        "ENABLE_IMAGE_GENERATION": "true",
        "ENABLE_VISION": "true",
        "ENABLE_MULTIMODAL": "true"
      },
      "transport": "stdio"
    }
  },
  "functions": [
    {
      "name": "chat_completion",
      "description": "Multi-turn conversation with any NIM LLM. Supports 50+ models including Nemotron 3 Ultra, DeepSeek V4 Pro, Kimi K2.6, GLM 5.1, Mistral Large 3.",
      "parameters": {
        "type": "object",
        "properties": {
          "model": { "type": "string", "description": "NIM model ID (e.g., nvidia/nemotron-3-ultra-550b-a55b, deepseek-ai/deepseek-v4-pro)" },
          "messages": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "role": { "type": "string", "enum": ["system", "user", "assistant"] },
                "content": { "type": "string" }
              },
              "required": ["role", "content"]
            },
            "minItems": 1
          },
          "system_prompt": { "type": "string" },
          "temperature": { "type": "number", "minimum": 0, "maximum": 2, "default": 0.3 },
          "top_p": { "type": "number", "minimum": 0, "maximum": 1, "default": 0.95 },
          "max_tokens": { "type": "integer", "minimum": 1, "maximum": 131072, "default": 4096 },
          "stop": { "oneOf": [{ "type": "string" }, { "type": "array", "items": { "type": "string" } }] },
          "seed": { "type": "integer" }
        },
        "required": ["messages"]
      }
    },
    {
      "name": "text_generation",
      "description": "Single-prompt text generation (simplified interface). Ideal for one-shot tasks.",
      "parameters": {
        "type": "object",
        "properties": {
          "model": { "type": "string" },
          "prompt": { "type": "string" },
          "system_prompt": { "type": "string" },
          "temperature": { "type": "number", "minimum": 0, "maximum": 2, "default": 0.3 },
          "max_tokens": { "type": "integer", "minimum": 1, "maximum": 131072, "default": 4096 },
          "stop": { "oneOf": [{ "type": "string" }, { "type": "array", "items": { "type": "string" } }] }
        },
        "required": ["prompt"]
      }
    },
    {
      "name": "create_embeddings",
      "description": "Convert text(s) to vector embeddings for RAG/search using NV-Embed, BGE-M3.",
      "parameters": {
        "type": "object",
        "properties": {
          "model": { "type": "string", "description": "Embedding model ID (e.g., nvidia/nv-embed-v1, baai/bge-m3)" },
          "input": { "oneOf": [{ "type": "string" }, { "type": "array", "items": { "type": "string" } }], "description": "Text or list of texts to embed" },
          "encoding_format": { "type": "string", "enum": ["float", "base64"], "default": "float" },
          "truncate": { "type": "string", "enum": ["NONE", "START", "END"], "default": "END" }
        },
        "required": ["input"]
      }
    },
    {
      "name": "rerank_passages",
      "description": "Rerank passages by relevance to a query using NV-RerankQA.",
      "parameters": {
        "type": "object",
        "properties": {
          "model": { "type": "string", "description": "Reranking model ID (e.g., nvidia/nv-rerankqa-mistral-4b-v3)" },
          "query": { "type": "string" },
          "passages": { "type": "array", "items": { "type": "object", "properties": { "text": { "type": "string" } } } },
          "top_k": { "type": "integer", "minimum": 1, "default": 10 }
        },
        "required": ["query", "passages"]
      }
    },
    {
      "name": "function_calling",
      "description": "Use NIM models with tool/function calling.",
      "parameters": {
        "type": "object",
        "properties": {
          "model": { "type": "string", "description": "Model with function calling support (e.g., z-ai/glm-5.1, nvidia/nemotron-3-ultra-550b-a55b)" },
          "messages": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "role": { "type": "string", "enum": ["system", "user", "assistant"] },
                "content": { "type": "string" }
              },
              "required": ["role", "content"]
            },
            "minItems": 1
          },
          "tools": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "type": { "type": "string", "enum": ["function"] },
                "function": {
                  "type": "object",
                  "properties": {
                    "name": { "type": "string" },
                    "description": { "type": "string" },
                    "parameters": { "type": "object" }
                  },
                  "required": ["name", "description", "parameters"]
                }
              },
              "required": ["type", "function"]
            }
          },
          "tool_choice": { "type": "string", "enum": ["auto", "none", "required"], "default": "auto" },
          "temperature": { "type": "number", "minimum": 0, "maximum": 2 },
          "max_tokens": { "type": "integer", "minimum": 1 }
        },
        "required": ["messages", "tools"]
      }
    },
    {
      "name": "generate_image",
      "description": "Generate images from text prompts using FLUX.1, SDXL, SD3, DiffusionGemma.",
      "parameters": {
        "type": "object",
        "properties": {
          "model": { "type": "string", "description": "Image generation model (e.g., black-forest-labs/flux.1-dev, nvidia/stable-diffusion-xl, stabilityai/sd-3-medium)" },
          "prompt": { "type": "string" },
          "negative_prompt": { "type": "string" },
          "width": { "type": "integer", "minimum": 64, "maximum": 2048, "default": 1024 },
          "height": { "type": "integer", "minimum": 64, "maximum": 2048, "default": 1024 },
          "num_images": { "type": "integer", "minimum": 1, "maximum": 4, "default": 1 },
          "steps": { "type": "integer", "minimum": 1, "maximum": 100, "default": 20 },
          "cfg_scale": { "type": "number", "minimum": 1, "maximum": 20, "default": 7.0 },
          "seed": { "type": "integer" },
          "sampler": { "type": "string", "description": "euler, euler_a, dpmpp_2m, dpmpp_sde, ddim" },
          "scheduler": { "type": "string", "description": "karras, exponential, simple, ddim_uniform" },
          "response_format": { "type": "string", "enum": ["url", "b64_json"], "default": "url" }
        },
        "required": ["prompt"]
      }
    },
    {
      "name": "analyze_image",
      "description": "Analyze and describe images using vision/multimodal models (Llama 3.2 Vision, Kimi K2.6, MiniMax M3, Phi-3.5 Vision).",
      "parameters": {
        "type": "object",
        "properties": {
          "model": { "type": "string", "description": "Vision model ID (e.g., meta/llama-3.2-90b-vision-instruct, moonshotai/kimi-k2.6)" },
          "image_url": { "type": "string", "format": "uri" },
          "prompt": { "type": "string" },
          "system_prompt": { "type": "string" },
          "temperature": { "type": "number", "minimum": 0, "maximum": 2, "default": 0.3 },
          "top_p": { "type": "number", "minimum": 0, "maximum": 1, "default": 0.95 },
          "max_tokens": { "type": "integer", "minimum": 1, "maximum": 4096, "default": 1024 },
          "detail": { "type": "string", "enum": ["low", "high", "auto"], "default": "auto" }
        },
        "required": ["image_url", "prompt"]
      }
    },
    {
      "name": "multimodal_task",
      "description": "Perform multimodal tasks combining text and images (MiniMax M3, Kimi K2.6, Qwen 3.5 397B, Mistral Large 3).",
      "parameters": {
        "type": "object",
        "properties": {
          "model": { "type": "string", "description": "Multimodal model ID" },
          "messages": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "role": { "type": "string", "enum": ["system", "user", "assistant"] },
                "content": {
                  "oneOf": [
                    { "type": "string" },
                    {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "type": { "type": "string", "enum": ["text", "image_url"] },
                          "text": { "type": "string" },
                          "image_url": {
                            "type": "object",
                            "properties": {
                              "url": { "type": "string", "format": "uri" },
                              "detail": { "type": "string", "enum": ["low", "high", "auto"] }
                            }
                          }
                        }
                      }
                    }
                  ]
                }
              },
              "required": ["role", "content"]
            },
            "minItems": 1
          },
          "temperature": { "type": "number", "minimum": 0, "maximum": 2, "default": 0.3 },
          "top_p": { "type": "number", "minimum": 0, "maximum": 1, "default": 0.95 },
          "max_tokens": { "type": "integer", "minimum": 1, "maximum": 4096, "default": 2048 },
          "stream": { "type": "boolean", "default": false }
        },
        "required": ["messages"]
      }
    },
    {
      "name": "list_models",
      "description": "List available models with rich metadata and advanced filtering for agent selection.",
      "parameters": {
        "type": "object",
        "properties": {
          "category": { "type": "string", "enum": ["language", "embedding", "reranking", "vision", "code", "multimodal", "image_generation", "all"], "default": "all" },
          "include_details": { "type": "boolean", "default": false },
          "commercial_use": { "type": "boolean" },
          "supports_reasoning": { "type": "boolean" },
          "supports_vision": { "type": "boolean" },
          "supports_function_calling": { "type": "boolean" },
          "supports_multimodal": { "type": "boolean" },
          "min_context_length": { "type": "integer", "minimum": 1 },
          "tags": { "type": "array", "items": { "type": "string" } },
          "hardware": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    {
      "name": "get_model_info",
      "description": "Get complete metadata for a specific model including licensing, hardware requirements, benchmarks, and capabilities.",
      "parameters": {
        "type": "object",
        "properties": {
          "model_id": { "type": "string" }
        },
        "required": ["model_id"]
      }
    },
    {
      "name": "compare_models",
      "description": "Compare 2-5 models side-by-side across all decision factors: licensing, hardware, benchmarks, capabilities, tags, image gen specs.",
      "parameters": {
        "type": "object",
        "properties": {
          "model_ids": {
            "type": "array",
            "items": { "type": "string" },
            "minItems": 2,
            "maxItems": 5
          }
        },
        "required": ["model_ids"]
      }
    }
  ],
  "model_categories": {
    "frontier_reasoning": [
      "nvidia/nemotron-3-ultra-550b-a55b",
      "deepseek-ai/deepseek-v4-pro",
      "moonshotai/kimi-k2.6",
      "z-ai/glm-5.1",
      "mistralai/mistral-large-3-675b-instruct-2512"
    ],
    "code_specialized": [
      "z-ai/glm-5.1",
      "z-ai/glm5",
      "qwen/qwen2.5-coder-32b-instruct"
    ],
    "multimodal_vision": [
      "minimaxai/minimax-m3",
      "moonshotai/kimi-k2.6",
      "meta/llama-3.2-90b-vision-instruct",
      "microsoft/phi-3.5-vision-instruct",
      "qwen/qwen3.5-397b-a17b",
      "mistralai/mistral-large-3-675b-instruct-2512"
    ],
    "image_generation": [
      "black-forest-labs/flux.1-dev",
      "black-forest-labs/flux.1-kontext-dev",
      "nvidia/stable-diffusion-xl",
      "stabilityai/sd-3-medium",
      "nvidia/sdxl-turbo"
    ],
    "open_weight": [
      "openai/gpt-oss-120b",
      "openai/gpt-oss-120b-chat"
    ]
  }
}