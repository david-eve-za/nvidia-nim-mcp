{
  "mcpServers": {
    "nvidia-nim": {
      "command": "node",
      "args": ["/absolute/path/to/nvidia-nim-mcp/dist/index.js"],
      "env": {
        "NVIDIA_API_KEY": "nvapi-your-api-key-here",
        "NVIDIA_NIM_BASE_URL": "https://integrate.api.nvidia.com/v1",
        "LOG_LEVEL": "info",
        "ENABLE_IMAGE_GENERATION": "true",
        "ENABLE_VISION": "true",
        "ENABLE_MULTIMODAL": "true"
      }
    }
  }
}